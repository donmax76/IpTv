<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:show_buffering="when_playing"
        app:use_controller="false"/>

    <!-- Custom overlay controls -->
    <RelativeLayout
        android:id="@+id/controlsOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#40000000">

        <!-- Top bar -->
        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:layout_alignParentTop="true">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:focusable="true"
                android:contentDescription="@string/back"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/channelName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:singleLine="true"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/epgNow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#B0FFFFFF"
                    android:textSize="13sp"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:visibility="gone"/>

            </LinearLayout>

            <!-- Clock display -->
            <TextView
                android:id="@+id/clockDisplay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginEnd="12dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/liveBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LIVE"
                android:textColor="@android:color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_live_badge"
                android:layout_marginEnd="8dp"/>

            <ImageButton
                android:id="@+id/btnChannelList"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_channel_list"
                android:tint="@android:color/white"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:focusable="true"
                android:layout_marginEnd="8dp"
                android:contentDescription="@string/channel_list"/>

            <ImageButton
                android:id="@+id/btnAspectRatio"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_aspect_ratio"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:focusable="true"
                android:contentDescription="@string/aspect_ratio"/>

        </LinearLayout>

        <!-- Center play/pause -->
        <ImageButton
            android:id="@+id/btnPlayPause"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_centerInParent="true"
            android:src="@drawable/ic_pause"
            android:background="@drawable/bg_player_control"
            android:scaleType="center"
            android:focusable="true"
            android:contentDescription="@string/play_pause"/>

        <!-- Bottom bar -->
        <LinearLayout
            android:id="@+id/bottomBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_alignParentBottom="true">

            <!-- Sleep timer indicator -->
            <TextView
                android:id="@+id/sleepTimerIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:textColor="@color/accent_orange"
                android:textSize="12sp"
                android:visibility="gone"
                android:layout_marginBottom="8dp"/>

            <!-- Channel navigation -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <ImageButton
                    android:id="@+id/btnPrevChannel"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_back"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:focusable="true"
                    android:contentDescription="@string/prev_channel"/>

                <TextView
                    android:id="@+id/channelNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"/>

                <ImageButton
                    android:id="@+id/btnNextChannel"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_back"
                    android:rotation="180"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:focusable="true"
                    android:contentDescription="@string/next_channel"/>

            </LinearLayout>

        </LinearLayout>

    </RelativeLayout>

    <!-- Semi-transparent channel list overlay panel -->
    <FrameLayout
        android:id="@+id/channelListOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <!-- Dim background (clickable to close) -->
        <View
            android:id="@+id/channelListDimBg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#80000000"/>

        <!-- Channel list panel -->
        <LinearLayout
            android:id="@+id/channelListPanel"
            android:layout_width="340dp"
            android:layout_height="match_parent"
            android:layout_gravity="start"
            android:orientation="vertical"
            android:background="@drawable/bg_overlay_panel"
            android:paddingTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/channels"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/overlayChannelCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#B0B0CC"
                    android:textSize="13sp"/>

            </LinearLayout>

            <!-- Search in channel list -->
            <EditText
                android:id="@+id/overlaySearchEdit"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_overlay_search"
                android:hint="@string/search_channels"
                android:textColor="@android:color/white"
                android:textColorHint="#80FFFFFF"
                android:textSize="13sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:singleLine="true"
                android:imeOptions="actionDone"
                android:inputType="text"/>

            <!-- Category chips for quick filter -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/overlayCategoriesList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:clipToPadding="false"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/overlayChannelsList"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="16dp"/>

        </LinearLayout>

    </FrameLayout>

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/loadingIndicator"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:indeterminateTint="@color/primary"
        android:visibility="gone"/>

    <!-- Error overlay -->
    <LinearLayout
        android:id="@+id/errorLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:id="@+id/errorText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/error_playback"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:layout_marginBottom="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRetry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/retry"
            android:backgroundTint="@color/primary"/>

    </LinearLayout>

    <!-- Channel number input overlay (for remote number input) -->
    <TextView
        android:id="@+id/numberInputDisplay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="80dp"
        android:layout_marginEnd="24dp"
        android:textColor="@android:color/white"
        android:textSize="48sp"
        android:textStyle="bold"
        android:background="#99000000"
        android:padding="16dp"
        android:visibility="gone"/>

</FrameLayout>
