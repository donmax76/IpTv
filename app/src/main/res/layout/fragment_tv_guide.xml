<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tv_guide"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/epgStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <ImageButton
            android:id="@+id/btnRefreshEpg"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_refresh"
            android:tint="@color/primary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:focusable="true"
            android:contentDescription="@string/epg_refresh"/>

    </LinearLayout>

    <!-- Search -->
    <EditText
        android:id="@+id/epgSearchEditText"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_search"
        android:drawableStart="@drawable/ic_search"
        android:drawablePadding="8dp"
        android:drawableTint="@color/text_hint"
        android:hint="@string/search_channels"
        android:textColorHint="@color/text_hint"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:inputType="text"
        android:imeOptions="actionSearch"
        android:singleLine="true"/>

    <!-- Date selector -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <ImageButton
            android:id="@+id/btnPrevDay"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_back"
            android:tint="@color/text_primary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:focusable="true"
            android:contentDescription="@string/prev_channel"/>

        <TextView
            android:id="@+id/tvCurrentDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/primary"
            android:textSize="15sp"
            android:textStyle="bold"/>

        <ImageButton
            android:id="@+id/btnNextDay"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_back"
            android:rotation="180"
            android:tint="@color/text_primary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:focusable="true"
            android:contentDescription="@string/next_channel"/>

    </LinearLayout>

    <!-- EPG List -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/epgRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="8dp"/>

        <ProgressBar
            android:id="@+id/epgProgressBar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:visibility="gone"
            android:indeterminateTint="@color/primary"/>

        <LinearLayout
            android:id="@+id/epgEmptyLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_tv_guide"
                android:tint="@color/text_hint"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/epgEmptyText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/epg_load_playlist_first"
                android:textColor="@color/text_hint"
                android:textSize="16sp"
                android:gravity="center"/>

        </LinearLayout>

    </FrameLayout>

</LinearLayout>
