<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.TVViewer" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#7C6CF7</item>
        <item name="colorPrimaryVariant">#5A4DC5</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">#00CEC9</item>
        <item name="colorSecondaryVariant">#009E9A</item>
        <item name="colorOnSecondary">@android:color/black</item>
        <item name="android:statusBarColor">@color/surface</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@android:color/white</item>
        <item name="bottomNavigationStyle">@style/Widget.TVViewer.BottomNavigation</item>
    </style>

    <style name="Theme.TVViewer.NoActionBar" parent="Theme.TVViewer">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Dialog theme - proper dark dialog with visible controls -->
    <style name="Theme.TVViewer.Dialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorPrimary">#7C6CF7</item>
        <item name="colorSecondary">#00CEC9</item>
        <item name="colorSurface">#2A2A48</item>
        <item name="colorOnSurface">@android:color/white</item>
        <item name="android:background">#2A2A48</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textColorPrimary">@android:color/white</item>
        <item name="android:textColorSecondary">#CCCCDD</item>
        <item name="colorControlNormal">#AAAACC</item>
        <item name="colorControlActivated">#7C6CF7</item>
        <item name="colorControlHighlight">#407C6CF7</item>
        <item name="materialAlertDialogTitleTextStyle">@style/DialogTitleStyle</item>
    </style>

    <style name="DialogTitleStyle" parent="MaterialAlertDialog.MaterialComponents.Title.Text">
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="Widget.TVViewer.BottomNavigation" parent="Widget.MaterialComponents.BottomNavigationView.Colored">
        <item name="android:background">@color/surface</item>
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
    </style>

    <style name="Theme.TVViewer.Player" parent="Theme.TVViewer">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="CardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
    </style>

    <style name="SearchBarStyle" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/card_background</item>
        <item name="boxCornerRadiusTopStart">24dp</item>
        <item name="boxCornerRadiusTopEnd">24dp</item>
        <item name="boxCornerRadiusBottomStart">24dp</item>
        <item name="boxCornerRadiusBottomEnd">24dp</item>
        <item name="boxStrokeColor">#7C6CF7</item>
        <item name="hintTextColor">#80FFFFFF</item>
    </style>

    <!-- Color Theme: Blue -->
    <style name="Theme.TVViewer.Blue" parent="Theme.TVViewer">
        <item name="colorPrimary">#2196F3</item>
        <item name="colorPrimaryVariant">#1976D2</item>
        <item name="colorSecondary">#03DAC5</item>
    </style>

    <!-- Color Theme: Green -->
    <style name="Theme.TVViewer.Green" parent="Theme.TVViewer">
        <item name="colorPrimary">#4CAF50</item>
        <item name="colorPrimaryVariant">#388E3C</item>
        <item name="colorSecondary">#00BCD4</item>
    </style>

    <!-- Color Theme: Orange -->
    <style name="Theme.TVViewer.Orange" parent="Theme.TVViewer">
        <item name="colorPrimary">#FF9800</item>
        <item name="colorPrimaryVariant">#F57C00</item>
        <item name="colorSecondary">#FFB74D</item>
    </style>

    <!-- Color Theme: Red -->
    <style name="Theme.TVViewer.Red" parent="Theme.TVViewer">
        <item name="colorPrimary">#F44336</item>
        <item name="colorPrimaryVariant">#D32F2F</item>
        <item name="colorSecondary">#FF7043</item>
    </style>
</resources>
