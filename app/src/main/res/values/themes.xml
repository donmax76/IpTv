<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.TVViewer" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#6C5CE7</item>
        <item name="colorPrimaryVariant">#4A3DB5</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">#00CEC9</item>
        <item name="colorSecondaryVariant">#009E9A</item>
        <item name="colorOnSecondary">@android:color/black</item>
        <item name="android:statusBarColor">#1A1A2E</item>
        <item name="android:navigationBarColor">#1A1A2E</item>
        <item name="android:windowBackground">#0F0F1A</item>
        <item name="colorSurface">#1A1A2E</item>
        <item name="colorOnSurface">@android:color/white</item>
        <item name="bottomNavigationStyle">@style/Widget.TVViewer.BottomNavigation</item>
    </style>

    <style name="Theme.TVViewer.NoActionBar" parent="Theme.TVViewer">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Widget.TVViewer.BottomNavigation" parent="Widget.MaterialComponents.BottomNavigationView.Colored">
        <item name="android:background">#1A1A2E</item>
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
    </style>

    <style name="Theme.TVViewer.Player" parent="Theme.TVViewer">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="CardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">#1E1E32</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
    </style>

    <style name="SearchBarStyle" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">#1E1E32</item>
        <item name="boxCornerRadiusTopStart">24dp</item>
        <item name="boxCornerRadiusTopEnd">24dp</item>
        <item name="boxCornerRadiusBottomStart">24dp</item>
        <item name="boxCornerRadiusBottomEnd">24dp</item>
        <item name="boxStrokeColor">#6C5CE7</item>
        <item name="hintTextColor">#80FFFFFF</item>
    </style>
</resources>
