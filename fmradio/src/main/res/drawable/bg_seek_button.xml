<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#44FFFFFF">
    <item>
        <layer-list>
            <!-- Outer ring -->
            <item>
                <shape android:shape="oval">
                    <solid android:color="#FF18181E" />
                </shape>
            </item>
            <!-- Metallic gradient - more premium look -->
            <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
                <shape android:shape="oval">
                    <gradient
                        android:startColor="#FF555565"
                        android:centerColor="#FF3C3C48"
                        android:endColor="#FF222230"
                        android:angle="315" />
                </shape>
            </item>
            <!-- Inner highlight -->
            <item android:left="3dp" android:top="3dp" android:right="3dp" android:bottom="3dp">
                <shape android:shape="oval">
                    <gradient
                        android:startColor="#FF454555"
                        android:endColor="#FF2A2A38"
                        android:angle="315" />
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>
