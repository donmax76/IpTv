<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/button_preset_active" />
            <corners android:radius="4dp" />
            <stroke android:width="1dp" android:color="@color/lcd_green" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/button_metal_pressed" />
            <corners android:radius="4dp" />
            <stroke android:width="1dp" android:color="#FF666666" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/button_preset" />
            <corners android:radius="4dp" />
            <stroke android:width="1dp" android:color="#FF444444" />
        </shape>
    </item>
</selector>
