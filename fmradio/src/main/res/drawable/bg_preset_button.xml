<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/button_preset_active" />
                    <corners android:radius="10dp" />
                    <stroke android:width="1.5dp" android:color="@color/lcd_green" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:startColor="#2200FF88"
                        android:endColor="#00000000"
                        android:angle="270" />
                    <corners android:radius="10dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/button_metal_pressed" />
            <corners android:radius="10dp" />
            <stroke android:width="1.5dp" android:color="#FF777777" />
        </shape>
    </item>
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:startColor="#FF303040"
                        android:endColor="#FF1A1A24"
                        android:angle="270" />
                    <corners android:radius="10dp" />
                    <stroke android:width="1dp" android:color="#FF404050" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
