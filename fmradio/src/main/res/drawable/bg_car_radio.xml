<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer shadow -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FF030306" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <!-- Metallic bezel highlight - subtle brushed metal effect -->
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/bezel_highlight"
                android:centerColor="@color/bezel_mid"
                android:endColor="@color/bezel_bottom"
                android:angle="270" />
            <corners android:radius="15dp" />
        </shape>
    </item>
    <!-- Inner shadow for depth -->
    <item android:left="3dp" android:top="3dp" android:right="3dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#FF08080C" />
            <corners android:radius="13dp" />
        </shape>
    </item>
    <!-- Inner panel with subtle gradient -->
    <item android:left="4dp" android:top="4dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FF151520"
                android:centerColor="#FF0E0E16"
                android:endColor="#FF0A0A10"
                android:angle="270" />
            <corners android:radius="12dp" />
        </shape>
    </item>
</layer-list>
